# ===================================
# HoloDex - Environment Config
# ===================================

# Server mode: api | mcp-stdio | mcp-http | all
MODE=all

# HTTP server port
PORT=3000

# Logging: debug | info | warn | error
LOG_LEVEL=info

# Output directory for generated PPTX files
OUTPUT_DIR=./output

# Brand configuration storage
BRAND_STORAGE_DIR=./brands

# CORS allowed origins (comma-separated, or * for all)
CORS_ORIGINS=*

# ===================================
# Azure Blob Storage (optional)
# ===================================
# When set, generated PPTX files are uploaded to Azure Blob Storage
# Uses DefaultAzureCredential (Managed Identity, az login, etc.)
AZURE_STORAGE_ACCOUNT=
AZURE_STORAGE_CONTAINER=pptx-output

# ===================================
# Azure Container App Settings
# ===================================
# These are set automatically when deployed to Azure Container Apps
# AZURE_CLIENT_ID=           # Managed identity client ID
# APPLICATIONINSIGHTS_CONNECTION_STRING=  # App Insights

# ===================================
# AI Image Generation (optional)
# ===================================
# Option 1: OpenAI (DALL-E 3 or GPT-image-1)
OPENAI_API_KEY=
AI_IMAGE_MODEL=gpt-image-1
# Options: gpt-image-1 (latest), dall-e-3 (stable)

# Option 2: Azure OpenAI with API key
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=dall-e-3
AZURE_OPENAI_API_VERSION=2024-02-01

# Option 3: Azure OpenAI with Entra ID (no API key needed)
# Set AZURE_OPENAI_ENDPOINT and AZURE_OPENAI_DEPLOYMENT above.
# Leave AZURE_OPENAI_API_KEY blank — uses DefaultAzureCredential
# (az login, Managed Identity, etc.) automatically.
# Requires "Cognitive Services OpenAI User" role on the resource.

# Provider preference: openai | azure-openai (auto-detected if omitted)
AI_IMAGE_PROVIDER=
